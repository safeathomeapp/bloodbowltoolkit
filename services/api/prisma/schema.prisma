generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeagueMembershipRole {
  OWNER
  MEMBER
}

enum TeamStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum TeamPlayerStatus {
  ACTIVE
  SOLD
  DEAD
  RETIRED
}

enum MatchSessionStatus {
  PENDING
  ACTIVE
  CLOSED
}

enum MatchSessionSide {
  HOME
  AWAY
}

enum CompetitionType {
  LEAGUE
  TOURNAMENT
}

enum CompetitionFormat {
  KNOCKOUT
  SWISS
  ROUND_ROBIN
}

enum CompetitionVisibility {
  PRIVATE
  INVITE_ONLY
  OPEN
}

enum CompetitionStatus {
  DRAFT
  OPEN_FOR_JOIN
  TEAM_SUBMISSION_OPEN
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum CompetitionEntryStatus {
  JOINED
  TEAM_PENDING
  TEAM_SUBMITTED
  TEAM_APPROVED
  ELIMINATED
  COMPLETED
  WITHDRAWN
}

enum TournamentTeamSourceType {
  COPIED_FROM_TEAM
  DIRECT_EVENT_BUILD
}

enum FixtureStatus {
  PENDING
  READY
  IN_PROGRESS
  COMPLETED
  VOID
}

enum FixtureSourceType {
  GENERATED
  COMMISSIONER_OVERRIDE
}

enum MatchSessionEventType {
  TOUCHDOWN
  CASUALTY
  COMPLETION
  INTERCEPTION
  MVP_ASSIGNMENT
}

enum MatchSessionCasualtyResolutionType {
  NONE
  MISS_NEXT_GAME
  NIGGLING_INJURY
  SERIOUS_INJURY
  LASTING_INJURY_ARMOUR
  LASTING_INJURY_MOVEMENT
  LASTING_INJURY_PASSING
  LASTING_INJURY_AGILITY
  LASTING_INJURY_STRENGTH
  DEAD
}

model User {
  id                    String                    @id @default(cuid())
  displayName           String
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  ownedLeagues          League[]                  @relation("LeagueOwner")
  leagueMemberships     LeagueMembership[]
  ownedTeams            Team[]
  createdMatchSessions  MatchSession[]            @relation("MatchSessionCreator")
  matchParticipants     MatchSessionParticipant[]
  createdCompetitions   Competition[]             @relation("CompetitionOwner")
  competitionEntries    CompetitionEntry[]
}

model League {
  id           String             @id @default(cuid())
  name         String
  createdById  String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  createdBy    User               @relation("LeagueOwner", fields: [createdById], references: [id])
  memberships  LeagueMembership[]
  teams        Team[]
  matchSessions MatchSession[]
}

model LeagueMembership {
  id        String               @id @default(cuid())
  leagueId  String
  userId    String
  role      LeagueMembershipRole
  joinedAt  DateTime             @default(now())
  league    League               @relation(fields: [leagueId], references: [id])
  user      User                 @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
}

model Team {
  id                    String       @id @default(cuid())
  ownerUserId           String
  leagueId              String?
  rosterTemplateId      String
  name                  String
  status                TeamStatus
  draftBudget           Int
  rerollCount           Int
  assistantCoachCount   Int
  cheerleaderCount      Int
  dedicatedFans         Int
  apothecaryPurchased   Boolean
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  owner                 User         @relation(fields: [ownerUserId], references: [id])
  league                League?      @relation(fields: [leagueId], references: [id])
  players               TeamPlayer[]
  homeSessions          MatchSession[] @relation("HomeTeam")
  awaySessions          MatchSession[] @relation("AwayTeam")
  sessionParticipants   MatchSessionParticipant[]
  competitionSubmissions CompetitionTeamSubmission[]
}

model TeamPlayer {
  id                String   @id @default(cuid())
  teamId            String
  positionTemplateId String
  name              String
  shirtNumber       Int?
  playerStatus      TeamPlayerStatus @default(ACTIVE)
  currentValue      Int
  spp               Int
  nigglingInjuries  Int
  missNextGame      Boolean  @default(false)
  isDead            Boolean  @default(false)
  extraSkills       String[]
  statAdjustments   Json
  displayOrder      Int
  team              Team     @relation(fields: [teamId], references: [id])

  @@index([teamId, displayOrder])
}

model MatchSession {
  id             String                   @id @default(cuid())
  leagueId       String?
  fixtureId      String?                  @unique
  homeTeamId     String
  awayTeamId     String
  sessionCode    String                   @unique
  status         MatchSessionStatus
  timerEnabled   Boolean                  @default(false)
  timerTurnSeconds Int?
  timerBankSeconds Int?
  timerBankResetsAtHalf Boolean           @default(true)
  timerCurrentHalf Int                    @default(1)
  timerCurrentTurnNumber Int              @default(1)
  timerActiveSide MatchSessionSide        @default(HOME)
  timerTurnStartedAt DateTime?
  timerHomeBankRemainingSeconds Int?
  timerAwayBankRemainingSeconds Int?
  homeFinalSignoffAt DateTime?
  awayFinalSignoffAt DateTime?
  closedAt       DateTime?
  progressionAppliedAt DateTime?
  createdByUserId String
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  league         League?                  @relation(fields: [leagueId], references: [id])
  fixture        Fixture?                 @relation(fields: [fixtureId], references: [id])
  homeTeam       Team                     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam       Team                     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  createdBy      User                     @relation("MatchSessionCreator", fields: [createdByUserId], references: [id])
  participants   MatchSessionParticipant[]
  events         MatchSessionEvent[]
  casualtyResolutions MatchSessionCasualtyResolution[]
  turnConfirmations MatchSessionTurnConfirmation[]
}

model MatchSessionParticipant {
  id             String           @id @default(cuid())
  matchSessionId String
  userId         String
  teamId         String
  side           MatchSessionSide
  matchSession   MatchSession     @relation(fields: [matchSessionId], references: [id])
  user           User             @relation(fields: [userId], references: [id])
  team           Team             @relation(fields: [teamId], references: [id])

  @@unique([matchSessionId, userId])
  @@unique([matchSessionId, side])
}

model MatchSessionEvent {
  id             String                @id @default(cuid())
  matchSessionId String
  half           Int
  turnNumber     Int
  actingSide     MatchSessionSide
  teamSide       MatchSessionSide
  injuredTeamSide MatchSessionSide?
  eventType      MatchSessionEventType
  playerNumber   Int?
  injuredPlayerNumber Int?
  notes          String?
  createdAt      DateTime              @default(now())
  matchSession   MatchSession          @relation(fields: [matchSessionId], references: [id])
  casualtyResolution MatchSessionCasualtyResolution?

  @@index([matchSessionId, half, turnNumber, actingSide, createdAt])
}

model MatchSessionTurnConfirmation {
  id              String           @id @default(cuid())
  matchSessionId  String
  half            Int
  turnNumber      Int
  side            MatchSessionSide
  homeConfirmedAt DateTime?
  awayConfirmedAt DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  matchSession    MatchSession     @relation(fields: [matchSessionId], references: [id])

  @@unique([matchSessionId, half, turnNumber, side])
}

model MatchSessionCasualtyResolution {
  id                 String                           @id @default(cuid())
  matchSessionId     String
  matchSessionEventId String                         @unique
  resolutionType     MatchSessionCasualtyResolutionType
  createdAt          DateTime                         @default(now())
  updatedAt          DateTime                         @updatedAt
  matchSession       MatchSession                     @relation(fields: [matchSessionId], references: [id])
  matchSessionEvent  MatchSessionEvent                @relation(fields: [matchSessionEventId], references: [id])

  @@index([matchSessionId])
}

model Competition {
  id                     String                @id @default(cuid())
  createdByUserId        String
  name                   String
  description            String?
  type                   CompetitionType
  format                 CompetitionFormat
  status                 CompetitionStatus
  visibility             CompetitionVisibility
  maxEntrants            Int
  submissionDeadline     DateTime?
  allowUnofficialRosters Boolean               @default(false)
  configJson             Json
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  createdBy              User                  @relation("CompetitionOwner", fields: [createdByUserId], references: [id])
  entries                CompetitionEntry[]
  fixtures               Fixture[]
}

model CompetitionEntry {
  id            String                 @id @default(cuid())
  competitionId String
  userId        String
  status        CompetitionEntryStatus
  joinedAt      DateTime               @default(now())
  submittedAt   DateTime?
  approvedAt    DateTime?
  seed          Int?
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  competition   Competition            @relation(fields: [competitionId], references: [id])
  user          User                   @relation(fields: [userId], references: [id])
  submission    CompetitionTeamSubmission?
  homeFixtures  Fixture[]              @relation("FixtureHomeEntry")
  awayFixtures  Fixture[]              @relation("FixtureAwayEntry")
  winningFixtures Fixture[]            @relation("FixtureWinnerEntry")

  @@unique([competitionId, userId])
  @@index([competitionId, status])
}

model CompetitionTeamSubmission {
  id                     String                      @id @default(cuid())
  competitionEntryId     String                      @unique
  sourceType             TournamentTeamSourceType
  sourceTeamId           String?
  rosterTemplateId       String
  teamName               String
  tierId                 String?
  teamValue              Int
  draftBudget            Int
  rerollCount            Int
  assistantCoachCount    Int
  cheerleaderCount       Int
  dedicatedFans          Int
  apothecaryPurchased    Boolean
  extraSkillsPackageJson Json
  submittedAt            DateTime
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  competitionEntry       CompetitionEntry            @relation(fields: [competitionEntryId], references: [id])
  sourceTeam             Team?                       @relation(fields: [sourceTeamId], references: [id])
  players                CompetitionTeamSubmissionPlayer[]
}

model CompetitionTeamSubmissionPlayer {
  id                          String                    @id @default(cuid())
  competitionTeamSubmissionId String
  sourcePlayerId              String?
  positionTemplateId          String
  name                        String
  shirtNumber                 Int?
  currentValue                Int
  displayOrder                Int
  extraSkills                 String[]
  statAdjustments             Json
  competitionTeamSubmission   CompetitionTeamSubmission @relation(fields: [competitionTeamSubmissionId], references: [id])

  @@index([competitionTeamSubmissionId, displayOrder])
}

model Fixture {
  id              String            @id @default(cuid())
  competitionId   String
  roundNumber     Int
  bracketPosition Int?
  homeEntryId     String?
  awayEntryId     String?
  status          FixtureStatus
  sourceType      FixtureSourceType
  scheduledAt     DateTime?
  nextFixtureId   String?
  winnerEntryId   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  competition     Competition       @relation(fields: [competitionId], references: [id])
  homeEntry       CompetitionEntry? @relation("FixtureHomeEntry", fields: [homeEntryId], references: [id])
  awayEntry       CompetitionEntry? @relation("FixtureAwayEntry", fields: [awayEntryId], references: [id])
  nextFixture     Fixture?          @relation("FixtureProgression", fields: [nextFixtureId], references: [id])
  previousFixtures Fixture[]        @relation("FixtureProgression")
  winnerEntry     CompetitionEntry? @relation("FixtureWinnerEntry", fields: [winnerEntryId], references: [id])
  matchSession    MatchSession?

  @@index([competitionId, roundNumber, bracketPosition])
}
